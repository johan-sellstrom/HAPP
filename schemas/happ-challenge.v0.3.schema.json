{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aaif.io/schemas/happ/challenge/v0.3.json",
  "title": "AAIF HAPP Challenge v0.3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "challengeId",
    "expiresAt",
    "requirements",
    "actionIntent"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "0.3"
    },
    "challengeId": {
      "type": "string",
      "format": "uuid"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pohp"
      ],
      "properties": {
        "pohp": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "minLevel"
          ],
          "properties": {
            "minLevel": {
              "type": "string",
              "enum": [
                "AAIF-PoHP-1",
                "AAIF-PoHP-2",
                "AAIF-PoHP-3",
                "AAIF-PoHP-4"
              ]
            },
            "maxCredentialAgeSeconds": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "identity": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mode"
          ],
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "none",
                "preferred",
                "required"
              ]
            },
            "schemes": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 0
            },
            "policy": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      }
    },
    "actionIntent": {
      "$ref": "action-intent.v0.3.schema.json"
    },
    "rpProof": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional RP signature over the challenge contents."
    }
  }
}