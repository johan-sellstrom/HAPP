{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aaif.io/schemas/happ/consent-credential/v0.3.json",
  "title": "AAIF HAPP Consent Credential Envelope v0.3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "credential",
    "claims"
  ],
  "properties": {
    "format": {
      "type": "string",
      "enum": [
        "jwt",
        "vc+json"
      ]
    },
    "credential": {
      "type": "string",
      "minLength": 20
    },
    "claims": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "issuer",
        "intent_hash",
        "presentation_hash",
        "aud",
        "jti",
        "iat",
        "exp",
        "assurance",
        "providerCertification"
      ],
      "properties": {
        "issuer": {
          "type": "string",
          "minLength": 3
        },
        "subject": {
          "type": "string"
        },
        "intent_hash": {
          "type": "string",
          "pattern": "^sha256:[A-Za-z0-9_-]{16,}$"
        },
        "presentation_hash": {
          "type": "string",
          "pattern": "^sha256:[A-Za-z0-9_-]{16,}$"
        },
        "aud": {
          "type": "string",
          "minLength": 3
        },
        "jti": {
          "type": "string",
          "minLength": 8
        },
        "iat": {
          "type": "integer"
        },
        "nbf": {
          "type": "integer"
        },
        "exp": {
          "type": "integer"
        },
        "assurance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "level",
            "verifiedAt",
            "method"
          ],
          "properties": {
            "level": {
              "type": "string",
              "enum": [
                "AAIF-PoHP-1",
                "AAIF-PoHP-2",
                "AAIF-PoHP-3",
                "AAIF-PoHP-4"
              ]
            },
            "verifiedAt": {
              "type": "string",
              "format": "date-time"
            },
            "method": {
              "type": "string",
              "minLength": 1
            },
            "deviceBinding": {
              "type": "string"
            }
          }
        },
        "identityBinding": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "mode",
            "scheme",
            "subject"
          ],
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "asserted",
                "verified"
              ]
            },
            "scheme": {
              "type": "string",
              "minLength": 1
            },
            "idp": {
              "type": "object",
              "additionalProperties": true
            },
            "subject": {
              "type": "object",
              "additionalProperties": true
            },
            "assurance": {
              "type": "object",
              "additionalProperties": true
            },
            "evidence": {
              "type": "object",
              "additionalProperties": true
            }
          }
        },
        "challengeId": {
          "type": "string",
          "format": "uuid"
        },
        "providerCertification": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "ref"
          ],
          "properties": {
            "ref": {
              "type": "string",
              "minLength": 10
            },
            "hash": {
              "type": "string"
            },
            "embedded": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
