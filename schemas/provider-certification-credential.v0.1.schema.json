{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aaif.io/schemas/happ/provider-certification/v0.1.json",
  "title": "AAIF HAPP Provider Certification Credential Claims v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "providerId",
    "certifiedLevels",
    "issuer",
    "issuedAt",
    "expiresAt"
  ],
  "properties": {
    "providerId": {
      "type": "string",
      "minLength": 3
    },
    "providerName": {
      "type": "string"
    },
    "certifiedLevels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "AAIF-PoHP-1",
          "AAIF-PoHP-2",
          "AAIF-PoHP-3",
          "AAIF-PoHP-4"
        ]
      }
    },
    "issuer": {
      "type": "string",
      "minLength": 3
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "lab": {
          "type": "string"
        },
        "reportId": {
          "type": "string"
        },
        "reportUrl": {
          "type": "string",
          "format": "uri"
        }
      }
    }
  }
}